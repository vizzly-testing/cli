{
  "name": "test-ember-app",
  "version": "0.0.0",
  "private": true,
  "description": "Test Ember app for @vizzly-testing/ember SDK development",
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "start": "vite",
    "test": "vite build --mode development && ember test --path dist"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/runtime": "^8.0.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.2",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.19",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.6.0",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.3",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.4",
    "@glimmer/component": "^2.1.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@warp-drive/ember": "~5.8.2",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^10.0.3",
    "decorator-transforms": "^2.3.2",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "~7.1.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-deprecation-workflow": "^4.0.1",
    "ember-data": "~5.8.2",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.1.0",
    "ember-template-lint": "^7.9.3",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.6",
    "qunit": "^2.25.0",
    "qunit-dom": "^3.5.1",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "testem": "^3.20.1",
    "tracked-built-ins": "^4.1.2",
    "vite": "^8.0.14"
  },
  "engines": {
    "node": ">= 20"
  },
  "ember": {
    "edition": "octane"
  },
  "dependencies": {
    "@vizzly-testing/ember": "file:.."
  }
}
